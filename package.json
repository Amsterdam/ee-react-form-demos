{
  "name": "ee-react-form-demos",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "start": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "lint:scripts": "eslint . --ext .ts,.tsx,.json",
    "lint:styles": "stylelint ./**/*.{css,scss}",
    "format:scripts": "prettier . --write",
    "format:styles": "stylelint ./**/*.{css,scss} --fix",
    "format": "npm run format:scripts && npm run format:styles",
    "prepare": "husky",
    "uninstall-husky": "npm uninstall husky --no-save && git config --unset core.hooksPath && npx rimraf .husky"
  },
  "devDependencies": {
    "@jls-digital/storybook-addon-code": "^2.0.0",
    "@storybook/addon-docs": "^9.1.2",
    "@storybook/addon-themes": "9.1.2",
    "@storybook/react-vite": "^9.1.2",
    "@stylistic/stylelint-plugin": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "@vitest/coverage-v8": "^4.0.15",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.4.49",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.7.4",
    "remark-gfm": "^4.0.1",
    "rimraf": "^6.0.1",
    "sass-embedded": "^1.89.0",
    "storybook": "^9.1.17",
    "stylelint": "^16.26.1",
    "stylelint-config-recommended": "^17.0.0",
    "stylelint-config-sass-guidelines": "^12.1.0",
    "stylelint-order": "^7.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "@amsterdam/design-system-assets": "^2.0.0",
    "@amsterdam/design-system-css": "3.1.0",
    "@amsterdam/design-system-react": "^3.1.0",
    "@amsterdam/design-system-react-icons": "^2.0.0",
    "@amsterdam/design-system-tokens": "^3.1.0",
    "@hookform/resolvers": "^5.1.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "es-toolkit": "^1.39.3",
    "install": "^0.13.0",
    "js-yaml": "^4.1.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.68.0",
    "react-select": "^5.10.2",
    "react-syntax-highlighter": "^15.6.1",
    "uuid": "^11.1.0",
    "zod": "^3.25.57"
  },
  "overrides": {
    "react-syntax-highlighter": {
      "prismjs": "1.30.0"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  }
}
